# if we want to apply multiple conditions across the rows and diiferent columns 
def binod(x):
    if x["height_cm"] < 170 and x["weight_kg"] < 70:
        return "light weight"
    elif x["height_cm"] < 180 and x["weight_kg"] < 80:
        return "middle weight"
    else:
        return "heavy weight"
bios["category"] = bios.apply(binod,axis=1)
bios.to_csv("C:/Users/Mr. Ahmed/Desktop/gpt practice/pandas/rando,.csv")

