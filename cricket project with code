def height(x):
    if x["height_cm"] > 175:
        return "Tall"
    elif x["height_cm"] > 165:
        return "average"
    else:
        return "Short"
# cricket["height_cat"] = cricket.apply(height,axis=1)
# Aother way to do this
def nahi(x):
    if x > 175:
        return "Tall"
    elif x > 165:
        return "average"
    else:
        return "Short"
cricket["height_cat"] = cricket["height_cm"].apply(nahi)
cricket

# Add a performance column → if runs > 3000 and wickets > 20 → "allrounder", 
# if runs > 3000 → "batsman", if wickets > 20 → "bowler", else → "developing"
def perfom(x):
    if x["runs"] > 3000 and x["wickets"] > 20:
        return "allrounder"
    elif x["runs"] > 3000:
        return "Batsman"
    elif x["wickets"] > 20:
        return "bowler"
    else:
        return "Developing"
cricket["Perfomance"] = cricket.apply(perfom,axis=1)
cricket

# Add a experience column → if matches > 100 → "senior" else "junior"
cricket["experience"] = np.where(cricket["matches"] > 100,"senior","junior")
cricket

